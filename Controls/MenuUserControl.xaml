<UserControl d:DesignHeight="670"
             d:DesignWidth="100"
             mc:Ignorable="d"
             x:Class="ParkingExpress.Controls.MenuUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
    <Button Content="Personal"
            Grid.Row="0"/>
    <Button Content="Roles"
            Grid.Row="1"/>
    <Button Content="Áreas"
            Grid.Row="2"/>
    <Button Content="Tarifas"
            Grid.Row="3"/>
    <Button Content="Ingreso y salida"
            Grid.Row="4"/>
    <Button Content="Usuarios"
            Grid.Row="6"/>
    <Button Content="Configuración"
            Grid.Row="7"/>
    </Grid>
</UserControl>
