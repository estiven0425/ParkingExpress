<Window d:DesignHeight="720"
        d:DesignWidth="1280"
        Icon="/Assets/Icons/parking_express.ico"
        mc:Ignorable="d"
        Title="Parking Express"
        WindowState="Maximized"
        x:Class="ParkingExpress.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:ParkingExpress.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <controls:MenuUserControl Grid.Column="0"
                                  Grid.Row="0"
                                  Grid.RowSpan="2"
                                  MaxWidth="100"/>
        <controls:EstadoUserControl Grid.Column="1"
                                    Grid.Row="0"
                                    MaxHeight="50"/>
        <ContentControl Content="{Binding VistaActual}"
                        Grid.Column="1"
                        Grid.Row="1">
        </ContentControl>
    </Grid>
</Window>
